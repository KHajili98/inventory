{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Web (CORS disabled)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--web-browser-flag",
        "--disable-web-security",
        "--web-browser-flag",
        "--user-data-dir=/tmp/flutter-chrome-dev"
      ]
    },
    {
      "name": "Flutter Web (release)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": ["-d", "chrome", "--release"]
    }
  ]
}
